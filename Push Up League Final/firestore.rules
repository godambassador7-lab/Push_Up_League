rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // Full profiles contain private account fields and are owner-only.
      allow read: if isOwner(userId);

      // Authenticated users can create/update their own profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);

      // Never allow deletion
      allow delete: if false;
    }

    // Workouts collection
    match /workouts/{workoutId} {
      // Workouts are private to the authenticated owner.
      allow read: if isOwner(resource.data.userId);

      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;

      // Never allow deletion (workouts should be locked, not deleted)
      allow delete: if false;
    }

    // Public, privacy-safe profile projection used by leaderboards.
    match /leaderboardProfiles/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId)
        && request.resource.data.userId == userId
        && request.resource.data.keys().hasOnly([
          'userId',
          'username',
          'normalizedUsername',
          'totalXp',
          'currentStreak',
          'currentRank',
          'isWorldRecordCandidate'
        ]);
      allow delete: if false;
    }

    // Achievements collection
    match /achievements/{achievementId} {
      // Achievements are private to the authenticated owner.
      allow read: if isOwner(resource.data.userId);

      allow create: if isOwner(request.resource.data.userId);

      // Never allow updates or deletions (achievements are permanent)
      allow update: if false;
      allow delete: if false;
    }

    // Deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
